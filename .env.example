# BFF 服务配置（复制为 .env 后修改，勿提交 .env）
PORT=8787
SESSION_SECRET=请改为随机长字符串
# 本地 HTTP 访问设为 false；HTTPS 反向代理后可设为 true
COOKIE_SECURE=false

# Qdrant（仅服务端可访问）
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
# 可选：只读 Key，viewer 代理读请求时使用
QDRANT_READ_KEY=

# Embedding 服务（仅服务端可访问）
EMBED_URL=http://127.0.0.1:8765
EMBED_API_KEY=

# Docker 构建（可选，默认已用国内镜像站）
# NODE_IMAGE=docker.m.daocloud.io/library/node:22-bookworm-slim
